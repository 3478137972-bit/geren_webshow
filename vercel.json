{
  "outputDirectory": "dist",
  "public": true,
  "rewrites": [
    { "source": "/images/(.*)", "destination": "/images/$1" }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
