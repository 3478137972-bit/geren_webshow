---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="作品集">
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-orange-50 to-white">
    <div class="max-w-[1600px] mx-auto px-8 text-center">
      <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6">设计作品</h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        1.5 年设计生涯，专注品牌全案设计。从品牌定位到视觉落地，为每个品牌打造独特的市场认知。
      </p>
    </div>
  </section>

  <!-- Portfolio Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-[1600px] mx-auto px-8 space-y-24">
      
      <!-- 捷客达便利店 -->
      <div id="jiekeda" class="scroll-reveal">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">捷客达便利店</h2>
          <p class="text-xl text-gray-600">品牌全案设计 | 24H 便捷生活新体验</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
          <img src="/images/brands/jiekeda/1.jpg" alt="捷客达便利店 - 品牌主视觉" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/jiekeda/2.jpg" alt="捷客达便利店 - 产品呈现" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/jiekeda/3.jpg" alt="捷客达便利店 - 标志规范" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/jiekeda/4.jpg" alt="捷客达便利店 - IP 形象" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/jiekeda/5.jpg" alt="捷客达便利店 - 触点设计" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
        </div>
      </div>

      <!-- 低卡特工 -->
      <div id="dikategong" class="scroll-reveal">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">低卡特工</h2>
          <p class="text-xl text-gray-600">中式轻食能量碗 | 低卡特工到减脂真有效</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-6">
          <img src="/images/brands/dikategong/1.jpg" alt="低卡特工 - 品牌主视觉" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/dikategong/2.jpg" alt="低卡特工 - 品牌视觉系统" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/dikategong/3.jpg" alt="低卡特工 - 品类定位" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/dikategong/4.jpg" alt="低卡特工 - 品牌命名" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/dikategong/5.jpg" alt="低卡特工 - 差异化定位" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/dikategong/6.jpg" alt="低卡特工 - 秒懂口号" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
        </div>
      </div>

      <!-- 一豌面 -->
      <div id="yiwannmian" class="scroll-reveal">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">一豌面</h2>
          <p class="text-xl text-gray-600">豌豆酸汤牛肉面开创者 | 酸爽劲道</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-6">
          <img src="/images/brands/yiwannmian/1.jpg" alt="一豌面 - 品牌主视觉" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/yiwannmian/2.jpg" alt="一豌面 - 标志基础规范" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/yiwannmian/3.jpg" alt="一豌面 - 品类命名" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/yiwannmian/4.jpg" alt="一豌面 - 品牌命名" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/yiwannmian/5.jpg" alt="一豌面 - 差异化定位" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/yiwannmian/6.jpg" alt="一豌面 - IP 形象设计" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
        </div>
      </div>

      <!-- 禾本轻甜 -->
      <div id="hebenqingtian" class="scroll-reveal">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">禾本轻甜</h2>
          <p class="text-xl text-gray-600">低糖现烤面包 | 轻甜选禾本现烤味更纯</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-6">
          <img src="/images/brands/hebenqingtian/1.jpg" alt="禾本轻甜 - 品牌主视觉" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/hebenqingtian/2.jpg" alt="禾本轻甜 - 店面设计" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/hebenqingtian/3.jpg" alt="禾本轻甜 - 品牌策划" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/hebenqingtian/4.jpg" alt="禾本轻甜 - 竞争格局" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/hebenqingtian/5.jpg" alt="禾本轻甜 - 品牌标识" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
          <img src="/images/brands/hebenqingtian/6.jpg" alt="禾本轻甜 - IP 形象设计" loading="lazy" onclick="openLightbox(this)" class="gallery-item rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 aspect-square object-cover hover-lift-premium cursor-pointer" />
        </div>
      </div>

    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-5xl mx-auto px-8 text-center">
      <h2 class="text-4xl font-bold text-gray-900 mb-6">有设计需求？</h2>
      <p class="text-xl text-gray-600 mb-8">
        从品牌策略到视觉落地，一站式解决你的品牌设计问题
      </p>
      <a href="/contact" class="btn-premium inline-block bg-white text-orange-500 px-12 py-6 rounded-2xl font-bold text-xl shadow-2xl hover:shadow-3xl scroll-reveal">
        立即联系
      </a>
    </div>
  </section>

  <!-- 图片放大灯箱 -->
  <div id="lightbox" class="fixed inset-0 bg-black/90 z-50 hidden" onclick="closeLightbox()">
    <div class="absolute top-4 right-4 text-white text-5xl cursor-pointer hover:text-gray-300 z-10" onclick="closeLightbox()">×</div>
    <div class="absolute top-4 left-4 text-white text-lg cursor-pointer hover:text-gray-300 z-10" onclick="prevImage()">← 上一张</div>
    <div class="absolute top-4 right-20 text-white text-lg cursor-pointer hover:text-gray-300 z-10" onclick="nextImage()">下一张 →</div>
    <div class="flex items-center justify-center h-full p-8">
      <img 
        id="lightbox-img"
        src="" 
        alt="放大查看"
        class="max-h-full max-w-full object-contain"
        onclick="event.stopPropagation()"
      />
    </div>
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 text-white text-lg bg-black/50 px-6 py-3 rounded-full">
      <span id="image-counter"></span>
    </div>
  </div>

  <!-- 滚动动画 + 灯箱功能脚本 -->
  <script>
    // 灯箱相关
    let currentImageIndex = 0;
    let allImages = [];

    function openLightbox(imgElement) {
      const lightbox = document.getElementById('lightbox');
      const lightboxImg = document.getElementById('lightbox-img');
      const counter = document.getElementById('image-counter');
      
      // 获取当前品牌的所有图片
      const brandGrid = imgElement.closest('.grid');
      allImages = Array.from(brandGrid.querySelectorAll('img'));
      currentImageIndex = allImages.indexOf(imgElement);
      
      updateLightboxImage();
      
      lightbox.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      const lightbox = document.getElementById('lightbox');
      if (lightbox) {
        lightbox.classList.add('hidden');
        document.body.style.overflow = '';
      }
    }

    function updateLightboxImage() {
      const lightboxImg = document.getElementById('lightbox-img');
      const counter = document.getElementById('image-counter');
      
      if (allImages[currentImageIndex]) {
        lightboxImg.src = allImages[currentImageIndex].src;
        lightboxImg.alt = allImages[currentImageIndex].alt;
        counter.textContent = `${currentImageIndex + 1} / ${allImages.length}`;
      }
    }

    function nextImage() {
      if (allImages.length > 0) {
        currentImageIndex = (currentImageIndex + 1) % allImages.length;
        updateLightboxImage();
      }
    }

    function prevImage() {
      if (allImages.length > 0) {
        currentImageIndex = (currentImageIndex - 1 + allImages.length) % allImages.length;
        updateLightboxImage();
      }
    }

    // ESC 键关闭灯箱
    document.addEventListener('keydown', (e) => {
      const lightbox = document.getElementById('lightbox');
      if (!lightbox || lightbox.classList.contains('hidden')) return;
      
      if (e.key === 'Escape') {
        closeLightbox();
      } else if (e.key === 'ArrowRight') {
        nextImage();
      } else if (e.key === 'ArrowLeft') {
        prevImage();
      }
    });

    // 滚动触发动画
    function initScrollReveal() {
      const elements = document.querySelectorAll('.scroll-reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
      
      elements.forEach(el => observer.observe(el));
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        initScrollReveal();
      });
    } else {
      initScrollReveal();
    }
  </script>
</BaseLayout>
