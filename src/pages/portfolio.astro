---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="作品集">
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <h1 class="text-5xl font-bold text-center mb-4">作品集</h1>
      <p class="text-center text-gray-500 mb-12">1.5 年设计生涯，专注品牌全案设计</p>
      
      <!-- 捷客达便利店 -->
      <div id="jiekeda" class="mb-20">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold text-gray-900">捷客达便利店</h2>
          <span class="bg-orange-100 text-orange-600 px-4 py-2 rounded-full text-sm font-medium">品牌全案</span>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          <img src="/images/brands/jiekeda/1.jpg" alt="捷客达便利店" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/jiekeda/2.jpg" alt="捷客达便利店" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/jiekeda/3.jpg" alt="捷客达便利店" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/jiekeda/4.jpg" alt="捷客达便利店" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/jiekeda/5.jpg" alt="捷客达便利店" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/jiekeda/6.jpg" alt="捷客达便利店" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
        </div>
      </div>

      <!-- 低卡特工 -->
      <div id="dikategong" class="mb-20">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold text-gray-900">低卡特工</h2>
          <span class="bg-green-100 text-green-600 px-4 py-2 rounded-full text-sm font-medium">中式轻食能量碗</span>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          <img src="/images/brands/dikategong/1.jpg" alt="低卡特工" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/dikategong/2.jpg" alt="低卡特工" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/dikategong/3.jpg" alt="低卡特工" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/dikategong/4.jpg" alt="低卡特工" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/dikategong/5.jpg" alt="低卡特工" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/dikategong/6.jpg" alt="低卡特工" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
        </div>
      </div>

      <!-- 一豌面 -->
      <div id="yiwannmian" class="mb-20">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold text-gray-900">一豌面</h2>
          <span class="bg-yellow-100 text-yellow-600 px-4 py-2 rounded-full text-sm font-medium">豌豆酸汤牛肉面</span>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          <img src="/images/brands/yiwannmian/1.jpg" alt="一豌面" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/yiwannmian/2.jpg" alt="一豌面" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/yiwannmian/3.jpg" alt="一豌面" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/yiwannmian/4.jpg" alt="一豌面" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/yiwannmian/5.jpg" alt="一豌面" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/yiwannmian/6.jpg" alt="一豌面" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
        </div>
      </div>

      <!-- 禾本轻甜 -->
      <div id="hebenqingtian" class="mb-20">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold text-gray-900">禾本轻甜</h2>
          <span class="bg-teal-100 text-teal-600 px-4 py-2 rounded-full text-sm font-medium">低糖现烤面包</span>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          <img src="/images/brands/hebenqingtian/1.jpg" alt="禾本轻甜" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/hebenqingtian/2.jpg" alt="禾本轻甜" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/hebenqingtian/3.jpg" alt="禾本轻甜" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/hebenqingtian/4.jpg" alt="禾本轻甜" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/hebenqingtian/5.jpg" alt="禾本轻甜" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
          <img src="/images/brands/hebenqingtian/6.jpg" alt="禾本轻甜" class="rounded-lg shadow-sm hover:shadow-md transition-shadow" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
