---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="关于">
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <h1 class="text-5xl font-bold text-center mb-12">关于我</h1>
      
      <!-- 关于我 - 左右布局 -->
      <div class="grid md:grid-cols-2 gap-12 items-center mb-16">
        <!-- 左边：文案 -->
        <div class="space-y-6">
          <div class="bg-orange-50 rounded-2xl p-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">乐乐</h2>
            <p class="text-xl text-gray-600 mb-6 leading-relaxed">
              AI 设计 SaaS 工具开发者，"秒懂 AI 超级员工"主理人。<br>
              AI 商业设计实战导师，专注不懂代码人群的 AI 商业落地。<br>
              极致降本极客，用 700 元二手电脑敲出商业级 AI 软件。
            </p>
            <div class="flex flex-wrap gap-4 text-sm text-gray-500">
              <span class="bg-white px-4 py-2 rounded-full">江苏镇江</span>
              <span class="bg-white px-4 py-2 rounded-full">1.5 年经验</span>
              <span class="bg-white px-4 py-2 rounded-full">平面设计师</span>
              <span class="bg-white px-4 py-2 rounded-full">AI 训练师</span>
            </div>
          </div>

          <!-- 核心主张 -->
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">核心主张</h2>
            <div class="grid gap-4">
              <div class="bg-gray-50 p-6 rounded-xl">
                <h3 class="text-lg font-semibold mb-2 text-gray-900">技术降维打击</h3>
                <p class="text-gray-600">牛逼的不是装备，是操作装备的人</p>
              </div>
              
              <div class="bg-gray-50 p-6 rounded-xl">
                <h3 class="text-lg font-semibold mb-2 text-gray-900">商业价值变现</h3>
                <p class="text-gray-600">我不卖"搬砖"的机会，我卖的是"变成包工头"的能力</p>
              </div>
              
              <div class="bg-gray-50 p-6 rounded-xl">
                <h3 class="text-lg font-semibold mb-2 text-gray-900">度义而后动</h3>
                <p class="text-gray-600">用免费筛选人品，用低价筛选诚意；不行就是天命</p>
              </div>
            </div>
          </div>
        </div>

        <!-- 右边：个人照片 -->
        <div class="flex justify-center">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-orange-400/30 to-amber-400/30 rounded-3xl blur-2xl"></div>
            <img 
              src="/images/lele-profile.jpg" 
              alt="乐乐"
              class="relative w-full max-w-md aspect-[3/4] object-cover rounded-3xl shadow-2xl"
            />
          </div>
        </div>
      </div>

      <!-- 线下活动照片 -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">线下活动</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <!-- AI 破局俱乐部 -->
          <div class="bg-gray-50 rounded-2xl overflow-hidden">
            <img 
              src="/images/activities/ai-club-group.jpg" 
              alt="AI 破局俱乐部线下活动"
              class="w-full h-64 object-cover"
            />
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">AI 破局俱乐部</h3>
              <p class="text-gray-600">与学员们一起探索 AI 时代的无限可能</p>
            </div>
          </div>

          <!-- 南京城市沙龙 -->
          <div class="bg-gray-50 rounded-2xl overflow-hidden">
            <img 
              src="/images/activities/nanjing-meetup.jpg" 
              alt="南京线下城市沙龙"
              class="w-full h-64 object-cover"
            />
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">南京城市沙龙</h3>
              <p class="text-gray-600">面对面交流 AI 实战经验与商业落地</p>
            </div>
          </div>
        </div>
      </div>

      <!-- 真实状态 -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-6">真实状态</h2>
        <div class="bg-gray-50 p-8 rounded-xl">
          <ul class="space-y-4 text-gray-700">
            <li class="flex items-start">
              <span class="text-orange-500 mr-3 font-bold">✓</span>
              <span>江苏大学工业设计专业</span>
            </li>
            <li class="flex items-start">
              <span class="text-orange-500 mr-3 font-bold">✓</span>
              <span>客户主动来找，不卷不累</span>
            </li>
            <li class="flex items-start">
              <span class="text-orange-500 mr-3 font-bold">✓</span>
              <span>AI 完成度 80-95%，细水长流</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- 联系方式 -->
      <div>
        <h2 class="text-3xl font-bold text-gray-900 mb-6">联系方式</h2>
        <div class="bg-orange-50 p-8 rounded-xl">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">邮箱</h3>
              <p class="text-gray-600">3478137972@qq.com</p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">微信</h3>
              <p class="text-gray-600">m347820705</p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">公众号</h3>
              <p class="text-gray-600">乐乐 AI 训练师</p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">小红书</h3>
              <p class="text-gray-600">乐乐 AI 训练师</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
