---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="联系">
  <section class="py-20 bg-gradient-to-br from-orange-50 to-white">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-5xl font-bold text-gray-900 mb-4">联系我</h1>
        <p class="text-gray-500 text-lg">有项目想合作？随时欢迎联系</p>
      </div>
      
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div class="bg-white rounded-2xl shadow-xl p-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">给我留言</h2>
          <form class="space-y-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">姓名</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
                placeholder="你的姓名"
              />
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">邮箱</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
                placeholder="your@email.com"
              />
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">留言</label>
              <textarea 
                id="message" 
                name="message" 
                rows="5" 
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors resize-none"
                placeholder="请简单描述你的需求..."
              ></textarea>
            </div>
            
            <button 
              type="submit"
              class="w-full bg-orange-500 text-white py-4 rounded-lg hover:bg-orange-600 transition-colors font-medium text-lg"
            >
              发送留言
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-6">
          <!-- Email -->
          <div class="bg-white rounded-2xl shadow-lg p-6 flex items-center gap-6">
            <div class="w-16 h-16 bg-orange-100 rounded-xl flex items-center justify-center text-3xl flex-shrink-0">
              📧
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">邮箱</div>
              <div class="text-lg font-medium text-gray-900">3478137972@qq.com</div>
            </div>
          </div>

          <!-- WeChat -->
          <div class="bg-white rounded-2xl shadow-lg p-6 flex items-center gap-6">
            <div class="w-16 h-16 bg-green-100 rounded-xl flex items-center justify-center text-3xl flex-shrink-0">
              💬
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">微信</div>
              <div class="text-lg font-medium text-gray-900">m347820705</div>
            </div>
          </div>

          <!-- Official Account -->
          <div class="bg-white rounded-2xl shadow-lg p-6 flex items-center gap-6">
            <div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center text-3xl flex-shrink-0">
              📱
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">公众号</div>
              <div class="text-lg font-medium text-gray-900">乐乐 AI 训练师</div>
            </div>
          </div>

          <!-- Xiaohongshu -->
          <div class="bg-white rounded-2xl shadow-lg p-6 flex items-center gap-6">
            <div class="w-16 h-16 bg-red-100 rounded-xl flex items-center justify-center text-3xl flex-shrink-0">
              📕
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">小红书</div>
              <div class="text-lg font-medium text-gray-900">乐乐 AI 训练师</div>
            </div>
          </div>

          <!-- QR Code Card -->
          <div class="bg-gradient-to-br from-orange-500 to-orange-600 rounded-2xl shadow-xl p-8 text-center">
            <h3 class="text-xl font-bold text-white mb-4">扫码加微信</h3>
            <img 
              src="/images/qrcode/wechat.jpg" 
              alt="微信二维码" 
              class="w-48 h-48 mx-auto bg-white rounded-xl shadow-lg mb-4"
            />
            <p class="text-white/90 text-sm">扫一扫上面的二维码图案，加我为朋友</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
