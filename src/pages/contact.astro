---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="联系">
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-5xl font-bold text-center mb-4">联系我</h1>
      <p class="text-center text-gray-500 mb-12 text-xl">有项目想合作？随时欢迎联系</p>
      
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">给我留言</h2>
          <form class="space-y-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">姓名</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
                placeholder="你的姓名"
              />
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">邮箱</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
                placeholder="your@email.com"
              />
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">留言</label>
              <textarea 
                id="message" 
                name="message" 
                rows="5" 
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors resize-none"
                placeholder="请简单描述你的需求..."
              ></textarea>
            </div>
            
            <button 
              type="submit"
              class="w-full bg-orange-500 text-white py-4 rounded-lg hover:bg-orange-600 transition-colors font-medium text-lg"
            >
              发送留言
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">其他方式</h2>
          
          <div class="space-y-6">
            <div class="bg-gray-50 p-6 rounded-xl">
              <div class="flex items-center gap-4">
                <div class="text-3xl">📧</div>
                <div>
                  <div class="text-sm text-gray-500">邮箱</div>
                  <div class="text-lg font-medium">3478137972@qq.com</div>
                </div>
              </div>
            </div>

            <div class="bg-gray-50 p-6 rounded-xl">
              <div class="flex items-center gap-4">
                <div class="text-3xl">💬</div>
                <div>
                  <div class="text-sm text-gray-500">微信</div>
                  <div class="text-lg font-medium">m347820705</div>
                </div>
              </div>
            </div>

            <div class="bg-gray-50 p-6 rounded-xl">
              <div class="flex items-center gap-4">
                <div class="text-3xl">📱</div>
                <div>
                  <div class="text-sm text-gray-500">公众号</div>
                  <div class="text-lg font-medium">乐乐 AI 训练师</div>
                </div>
              </div>
            </div>

            <div class="bg-gray-50 p-6 rounded-xl">
              <div class="flex items-center gap-4">
                <div class="text-3xl">📕</div>
                <div>
                  <div class="text-sm text-gray-500">小红书</div>
                  <div class="text-lg font-medium">乐乐 AI 训练师</div>
                </div>
              </div>
            </div>
          </div>

          <!-- QR Code -->
          <div class="mt-8 bg-orange-50 p-6 rounded-xl text-center">
            <h3 class="font-semibold text-gray-900 mb-4">扫码加微信</h3>
            <img src="/images/qrcode/wechat.jpg" alt="微信二维码" class="w-48 h-48 mx-auto bg-white rounded-lg" />
            <p class="text-sm text-gray-500 mt-4">扫一扫上面的二维码图案，加我为朋友</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
