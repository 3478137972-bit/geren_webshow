---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="首页">
  <!-- Hero Section with Profile -->
  <section class="min-h-[90vh] flex items-center justify-center bg-gradient-to-br from-orange-50 via-white to-gray-50 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <!-- Profile Image -->
        <div class="flex justify-center md:justify-end order-2 md:order-1">
          <div class="relative group">
            <div class="absolute inset-0 bg-orange-500/20 rounded-3xl transform rotate-3 group-hover:rotate-6 transition-transform duration-500"></div>
            <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 to-transparent rounded-3xl"></div>
            <img 
              src="/images/lele-profile.jpg" 
              alt="乐乐 AI 训练师"
              class="relative w-80 h-80 md:w-96 md:h-96 object-cover rounded-3xl shadow-2xl hover:shadow-3xl transition-all duration-500 hover-lift"
            />
            <!-- Floating Badge -->
            <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl p-4 animate-float">
              <div class="text-3xl mb-1">🚀</div>
              <div class="text-sm font-semibold text-gray-900">AI 训练师</div>
            </div>
          </div>
        </div>
        
        <!-- Hero Content -->
        <div class="text-center md:text-left order-1 md:order-2">
          <div class="inline-block bg-orange-100 text-orange-600 px-4 py-2 rounded-full text-sm font-medium mb-6 animate-fade-in-up">
             AI 训练师 | 🎨 平面设计师
          </div>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight animate-fade-in-up delay-200">
            乐乐 AI<br/>训练师
          </h1>
          <p class="text-xl md:text-2xl text-gray-600 mb-8 leading-relaxed animate-fade-in-up delay-300">
            一个用 AI 为设计、产品、运营赋能的 AI 训练师<br/>
            <span class="text-orange-500 font-semibold">用 700 元二手电脑</span>敲出商业级 AI 软件
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center md:justify-start gap-4 animate-fade-in-up delay-400">
            <a href="/portfolio" class="w-full sm:w-auto bg-orange-500 text-white px-8 py-4 rounded-lg hover:bg-orange-600 transition-all font-medium text-lg text-center btn-click hover-lift shadow-lg hover:shadow-xl">
              查看作品 →
            </a>
            <a href="/course" class="w-full sm:w-auto border-2 border-orange-500 text-orange-500 px-8 py-4 rounded-lg hover:bg-orange-50 transition-all font-medium text-lg text-center btn-click hover-lift">
              AI 实战营
            </a>
          </div>
          
          <!-- Stats -->
          <div class="grid grid-cols-3 gap-6 mt-12 pt-12 border-t border-gray-200 scroll-reveal">
            <div class="text-center md:text-left group">
              <div class="text-3xl font-bold text-orange-500 group-hover:scale-110 transition-transform">1.5 年</div>
              <div class="text-gray-500 text-sm mt-1">设计经验</div>
            </div>
            <div class="text-center md:text-left group">
              <div class="text-3xl font-bold text-orange-500 group-hover:scale-110 transition-transform">4+</div>
              <div class="text-gray-500 text-sm mt-1">品牌全案</div>
            </div>
            <div class="text-center md:text-left group">
              <div class="text-3xl font-bold text-orange-500 group-hover:scale-110 transition-transform">100%</div>
              <div class="text-gray-500 text-sm mt-1">AI 赋能</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Works -->
  <section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16 scroll-reveal">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">精选作品</h2>
        <p class="text-gray-500 text-lg">1.5 年设计生涯，专注品牌全案设计</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- 捷客达便利店 -->
        <a href="/portfolio#jiekeda" class="group scroll-reveal">
          <div class="aspect-square bg-orange-100 rounded-2xl overflow-hidden mb-4 shadow-md group-hover:shadow-2xl transition-all duration-500">
            <img 
              src="/images/brands/jiekeda/1.jpg" 
              alt="捷客达便利店"
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            />
          </div>
          <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-500 transition-colors">捷客达便利店</h3>
          <p class="text-gray-500 mt-1">品牌全案</p>
        </a>

        <!-- 低卡特工 -->
        <a href="/portfolio#dikategong" class="group scroll-reveal delay-100">
          <div class="aspect-square bg-green-100 rounded-2xl overflow-hidden mb-4 shadow-md group-hover:shadow-2xl transition-all duration-500">
            <img 
              src="/images/brands/dikategong/1.jpg" 
              alt="低卡特工"
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            />
          </div>
          <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-500 transition-colors">低卡特工</h3>
          <p class="text-gray-500 mt-1">中式轻食能量碗</p>
        </a>

        <!-- 一豌面 -->
        <a href="/portfolio#yiwannmian" class="group scroll-reveal delay-200">
          <div class="aspect-square bg-yellow-100 rounded-2xl overflow-hidden mb-4 shadow-md group-hover:shadow-2xl transition-all duration-500">
            <img 
              src="/images/brands/yiwannmian/1.jpg" 
              alt="一豌面"
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            />
          </div>
          <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-500 transition-colors">一豌面</h3>
          <p class="text-gray-500 mt-1">豌豆酸汤牛肉面</p>
        </a>

        <!-- 禾本轻甜 -->
        <a href="/portfolio#hebenqingtian" class="group scroll-reveal delay-300">
          <div class="aspect-square bg-teal-100 rounded-2xl overflow-hidden mb-4 shadow-md group-hover:shadow-2xl transition-all duration-500">
            <img 
              src="/images/brands/hebenqingtian/1.jpg" 
              alt="禾本轻甜"
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            />
          </div>
          <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-500 transition-colors">禾本轻甜</h3>
          <p class="text-gray-500 mt-1">低糖现烤面包</p>
        </a>
      </div>

      <div class="text-center mt-12 scroll-reveal">
        <a href="/portfolio" class="inline-block border-2 border-orange-500 text-orange-500 px-8 py-3 rounded-lg hover:bg-orange-500 hover:text-white transition-all font-medium btn-click hover-lift">
          查看全部作品 →
        </a>
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-4xl font-bold mb-8 scroll-reveal">关于我</h2>
      <p class="text-lg text-gray-600 mb-12 leading-relaxed scroll-reveal delay-100">
        AI 设计 SaaS 工具开发者，"秒懂 AI 超级员工"主理人。<br/>
        AI 商业设计实战导师，专注不懂代码人群的 AI 商业落地。<br/>
        极致降本极客，用 700 元二手电脑敲出商业级 AI 软件。
      </p>
      
      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div class="bg-white p-8 rounded-2xl shadow-sm hover-lift scroll-reveal delay-200">
          <div class="text-5xl mb-4 animate-pulse-slow">💡</div>
          <h3 class="text-xl font-semibold mb-3">技术降维打击</h3>
          <p class="text-gray-600">牛逼的不是装备，是操作装备的人</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm hover-lift scroll-reveal delay-300">
          <div class="text-5xl mb-4 animate-pulse-slow delay-200">🎯</div>
          <h3 class="text-xl font-semibold mb-3">商业价值变现</h3>
          <p class="text-gray-600">我不卖"搬砖"的机会，我卖的是"变成包工头"的能力</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm hover-lift scroll-reveal delay-400">
          <div class="text-5xl mb-4 animate-pulse-slow delay-400">⚖️</div>
          <h3 class="text-xl font-semibold mb-3">度义而后动</h3>
          <p class="text-gray-600">用免费筛选人品，用低价筛选诚意</p>
        </div>
      </div>

      <div class="mt-12 scroll-reveal delay-500">
        <a href="/about" class="inline-block bg-orange-500 text-white px-8 py-4 rounded-lg hover:bg-orange-600 transition-all font-medium text-lg btn-click hover-lift shadow-lg hover:shadow-xl">
          了解更多 →
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-gradient-to-r from-orange-500 to-orange-600 text-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-4xl font-bold mb-6 scroll-reveal">有项目想合作？</h2>
      <p class="text-xl mb-8 opacity-90 scroll-reveal delay-100">
        无论是品牌设计还是 AI 培训，我都可以帮你
      </p>
      <a href="/contact" class="inline-block bg-white text-orange-500 px-8 py-4 rounded-lg hover:bg-gray-100 transition-all font-medium text-lg btn-click hover-lift shadow-xl">
        立即联系 →
      </a>
    </div>
  </section>

  <!-- Scroll Animation Script -->
  <script>
    // 滚动触发动画
    function initScrollReveal() {
      const elements = document.querySelectorAll('.scroll-reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -100px 0px'
      });
      
      elements.forEach(el => observer.observe(el));
    }
    
    // 页面加载后初始化
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScrollReveal);
    } else {
      initScrollReveal();
    }
  </script>
</BaseLayout>
