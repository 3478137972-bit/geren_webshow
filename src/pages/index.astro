---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="首页">
  <!-- 滚动进度条 -->
  <div class="scroll-progress" id="scrollProgress"></div>
  
  <!-- Hero Section - 创意视觉 -->
  <section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-orange-50 via-white to-amber-50 overflow-hidden relative">
    <!-- 粒子背景 -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute bottom-0 left-1/4 w-2 h-2 bg-orange-400 rounded-full opacity-0 animate-particle-float" style="animation-delay: 0s; animation-duration: 15s;"></div>
      <div class="absolute bottom-0 left-1/2 w-3 h-3 bg-orange-300 rounded-full opacity-0 animate-particle-float" style="animation-delay: 2s; animation-duration: 18s;"></div>
      <div class="absolute bottom-0 right-1/4 w-2 h-2 bg-amber-400 rounded-full opacity-0 animate-particle-float" style="animation-delay: 4s; animation-duration: 20s;"></div>
      <div class="absolute bottom-0 left-1/3 w-1 h-1 bg-orange-500 rounded-full opacity-0 animate-particle-float" style="animation-delay: 1s; animation-duration: 16s;"></div>
      <div class="absolute bottom-0 right-1/3 w-2 h-2 bg-orange-200 rounded-full opacity-0 animate-particle-float" style="animation-delay: 3s; animation-duration: 19s;"></div>
    </div>
    
    <!-- 装饰性光晕 -->
    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-orange-300/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-amber-300/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    
    <div class="max-w-[1600px] mx-auto px-8 py-20 relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Profile Image - 3D 悬浮效果 -->
        <div class="flex justify-center lg:justify-end order-2 lg:order-2">
          <div class="relative group">
            <!-- 旋转光晕环 -->
            <div class="absolute inset-0 border-4 border-orange-300/30 rounded-[2.5rem] animate-spin-slow" style="animation-duration: 20s;"></div>
            <div class="absolute inset-0 border-4 border-orange-400/20 rounded-[2.5rem] animate-spin-slow" style="animation-duration: 15s; animation-direction: reverse;"></div>
            
            <!-- 光晕背景 -->
            <div class="absolute inset-0 bg-gradient-to-br from-orange-400/30 to-amber-400/30 rounded-[2.5rem] blur-2xl group-hover:blur-3xl transition-all duration-500 animate-pulse-glow"></div>
            
            <!-- 主图 -->
            <div class="relative animate-float-3d">
              <div class="absolute inset-0 bg-gradient-to-br from-orange-500/20 to-transparent rounded-[2.5rem]"></div>
              <img 
                src="/images/lele-profile.jpg" 
                alt="乐乐 AI 训练师"
                class="relative w-80 h-80 md:w-[420px] md:h-[420px] object-cover rounded-[2.5rem] shadow-2xl group-hover:shadow-3xl transition-all duration-500"
                style="filter: drop-shadow(0 25px 50px rgba(249, 115, 22, 0.3));"
              />
              
              <!-- 悬浮徽章 -->
              <div class="absolute -top-6 -right-6 bg-white rounded-3xl shadow-2xl p-5 animate-bounce-in card-3d">
                <div class="flex items-center gap-3">
                  <div>
                    <div class="text-xs text-gray-500 font-medium">AI 训练师</div>
                    <div class="text-lg font-bold text-gray-900">乐乐</div>
                  </div>
                </div>
              </div>
              
              <!-- 数据标签 -->
              <div class="absolute -bottom-4 -left-4 bg-white/90 backdrop-blur-sm rounded-2xl shadow-xl p-4 animate-slide-up-fade">
                <div class="flex items-center gap-4">
                  <div class="text-center">
                    <div class="text-2xl font-bold text-gradient">1.5 年</div>
                    <div class="text-xs text-gray-500">经验</div>
                  </div>
                  <div class="w-px h-10 bg-gray-200"></div>
                  <div class="text-center">
                    <div class="text-2xl font-bold text-gradient">4+</div>
                    <div class="text-xs text-gray-500">品牌</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Hero Content - 文字动效 -->
        <div class="text-center lg:text-left order-1 lg:order-1">
          <!-- 标签 -->
          <div class="inline-flex items-center gap-2 bg-gradient-to-r from-orange-100 to-amber-100 text-orange-600 px-6 py-3 rounded-full text-sm font-bold mb-8 animate-slide-up-fade shadow-lg hover-lift-premium">
            <span>AI 训练师 | 平面设计师</span>
          </div>
          
          <!-- 主标题 - 渐变流动 -->
          <h1 class="text-6xl md:text-7xl lg:text-8xl font-black text-gray-900 mb-8 leading-tight animate-glow">
            <span class="text-gradient">乐乐 AI</span><br/>
            <span class="text-gradient" style="animation-delay: 0.5s;">训练师</span>
          </h1>
          
          <!-- 副标题 -->
          <p class="text-xl md:text-2xl text-gray-600 mb-10 leading-relaxed animate-slide-up-fade" style="animation-delay: 0.3s;">
            一个用 <span class="text-orange-500 font-bold">AI</span> 为设计、产品、运营赋能的 AI 训练师<br/>
            <span class="inline-block mt-2 bg-gradient-to-r from-orange-500 to-amber-500 text-white px-6 py-2 rounded-full text-lg font-bold animate-pulse">
              用 700 元二手电脑敲出商业级 AI 软件
            </span>
          </p>
          
          <!-- CTA 按钮 -->
          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-5 animate-slide-up-fade" style="animation-delay: 0.5s;">
            <a href="/portfolio" class="btn-premium text-white px-10 py-5 rounded-xl font-bold text-lg shadow-xl">
              查看作品
            </a>
            <a href="/course" class="group relative px-10 py-5 rounded-xl font-bold text-lg border-2 border-orange-500 text-orange-500 hover:bg-orange-500 hover:text-white transition-all duration-300 hover-lift-premium overflow-hidden">
              <span class="relative z-10">AI 实战营</span>
              <div class="absolute inset-0 bg-orange-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
            </a>
          </div>
          
          <!-- 特色标签 -->
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3 mt-12 animate-slide-up-fade" style="animation-delay: 0.7s;">
            <span class="px-4 py-2 bg-orange-100 text-orange-600 rounded-lg text-sm font-semibold">技术降维</span>
            <span class="px-4 py-2 bg-amber-100 text-amber-600 rounded-lg text-sm font-semibold">商业变现</span>
            <span class="px-4 py-2 bg-red-100 text-red-600 rounded-lg text-sm font-semibold">极致降本</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 精选作品 - 瀑布流展示 -->
  <section class="py-32 bg-white relative overflow-hidden">
    <!-- 背景装饰 -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-orange-200 to-transparent"></div>
    
    <div class="max-w-[1600px] mx-auto px-8 relative z-10">
      <div class="text-center mb-20 scroll-reveal">
        <span class="inline-block bg-orange-100 text-orange-600 px-6 py-2 rounded-full text-sm font-bold mb-4">精选案例</span>
        <h2 class="text-5xl md:text-6xl font-black text-gray-900 mb-6">设计作品</h2>
        <p class="text-xl text-gray-500">1.5 年设计生涯，专注品牌全案设计</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- 捷客达便利店 -->
        <a href="/portfolio#jiekeda" class="group scroll-reveal">
          <div class="stack-card aspect-square bg-gradient-to-br from-orange-100 to-amber-100 rounded-3xl overflow-hidden mb-6">
            <img 
              src="/images/brands/jiekeda/1.jpg" 
              alt="捷客达便利店"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="text-center">
            <h3 class="text-2xl font-bold text-gray-900 group-hover:text-gradient transition-all">捷客达便利店</h3>
            <p class="text-gray-500 mt-2 font-medium">品牌全案设计</p>
          </div>
        </a>

        <!-- 低卡特工 -->
        <a href="/portfolio#dikategong" class="group scroll-reveal" style="animation-delay: 0.1s;">
          <div class="stack-card aspect-square bg-gradient-to-br from-green-100 to-emerald-100 rounded-3xl overflow-hidden mb-6">
            <img 
              src="/images/brands/dikategong/1.jpg" 
              alt="低卡特工"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="text-center">
            <h3 class="text-2xl font-bold text-gray-900 group-hover:text-gradient transition-all">低卡特工</h3>
            <p class="text-gray-500 mt-2 font-medium">中式轻食能量碗</p>
          </div>
        </a>

        <!-- 一豌面 -->
        <a href="/portfolio#yiwannmian" class="group scroll-reveal" style="animation-delay: 0.2s;">
          <div class="stack-card aspect-square bg-gradient-to-br from-yellow-100 to-amber-100 rounded-3xl overflow-hidden mb-6">
            <img 
              src="/images/brands/yiwannmian/1.jpg" 
              alt="一豌面"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="text-center">
            <h3 class="text-2xl font-bold text-gray-900 group-hover:text-gradient transition-all">一豌面</h3>
            <p class="text-gray-500 mt-2 font-medium">豌豆酸汤牛肉面</p>
          </div>
        </a>

        <!-- 禾本轻甜 -->
        <a href="/portfolio#hebenqingtian" class="group scroll-reveal" style="animation-delay: 0.3s;">
          <div class="stack-card aspect-square bg-gradient-to-br from-teal-100 to-cyan-100 rounded-3xl overflow-hidden mb-6">
            <img 
              src="/images/brands/hebenqingtian/1.jpg" 
              alt="禾本轻甜"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="text-center">
            <h3 class="text-2xl font-bold text-gray-900 group-hover:text-gradient transition-all">禾本轻甜</h3>
            <p class="text-gray-500 mt-2 font-medium">低糖现烤面包</p>
          </div>
        </a>
      </div>

      <div class="text-center mt-16 scroll-reveal">
        <a href="/portfolio" class="btn-premium inline-block text-white px-10 py-5 rounded-xl font-bold text-lg shadow-xl">
          查看全部作品 →
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-32 bg-gradient-to-r from-orange-500 via-orange-600 to-amber-500 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    
    <div class="max-w-5xl mx-auto px-8 text-center relative z-10">
      <h2 class="text-5xl md:text-6xl font-black mb-8 scroll-reveal animate-glow">有项目想合作？</h2>
      <p class="text-2xl mb-12 opacity-95 scroll-reveal">无论是品牌设计还是 AI 培训，我都可以帮你</p>
      <a href="/contact" class="btn-premium inline-block bg-white text-orange-500 px-12 py-6 rounded-2xl font-bold text-xl shadow-2xl hover:shadow-3xl scroll-reveal">
        立即联系
      </a>
    </div>
  </section>

  <!-- Scripts -->
  <script>
    // 粒子动画 CSS
    const style = document.createElement('style');
    style.textContent = `
      @keyframes particleFloat {
        0%, 100% { transform: translateY(0) translateX(0); opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { transform: translateY(-100vh) translateX(50px); opacity: 0; }
      }
      .animate-particle-float {
        animation: particleFloat linear infinite;
      }
      @keyframes spin-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      .animate-spin-slow {
        animation: spin-slow linear infinite;
      }
    `;
    document.head.appendChild(style);

    // 滚动进度条
    function updateScrollProgress() {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      document.getElementById('scrollProgress').style.width = scrolled + '%';
    }
    
    window.addEventListener('scroll', updateScrollProgress);

    // 滚动触发动画
    function initScrollReveal() {
      const elements = document.querySelectorAll('.scroll-reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
      
      elements.forEach(el => observer.observe(el));
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScrollReveal);
    } else {
      initScrollReveal();
    }
  </script>
</BaseLayout>
