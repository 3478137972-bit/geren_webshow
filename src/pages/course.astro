---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="课程">
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-orange-50 to-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <!-- 左边：标题 + 组件 -->
        <div class="space-y-8">
          <div>
            <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-4">AI 实战营</h1>
            <p class="text-xl text-gray-600">从 0 到 1 搭建你的 AI 商业系统</p>
            <div class="inline-block bg-orange-500 text-white px-6 py-3 rounded-full font-medium mt-4">
              我们只解决 4 个死穴
            </div>
          </div>
          
          <!-- UI 组件展示卡片 -->
          <div class="grid grid-cols-2 gap-6">
            <div class="bg-white border-2 border-orange-200 rounded-xl p-6 hover:border-orange-500 transition-colors">
              <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              <div class="text-base font-semibold text-gray-900">获客系统</div>
            </div>
            <div class="bg-white border-2 border-orange-200 rounded-xl p-6 hover:border-orange-500 transition-colors">
              <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
              </div>
              <div class="text-base font-semibold text-gray-900">内容系统</div>
            </div>
            <div class="bg-white border-2 border-orange-200 rounded-xl p-6 hover:border-orange-500 transition-colors">
              <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div class="text-base font-semibold text-gray-900">成交系统</div>
            </div>
            <div class="bg-white border-2 border-orange-200 rounded-xl p-6 hover:border-orange-500 transition-colors">
              <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div class="text-base font-semibold text-gray-900">交付系统</div>
            </div>
          </div>
        </div>
        
        <!-- 右边：课程图片 -->
        <div class="flex justify-center">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-orange-400/30 to-amber-400/30 rounded-3xl blur-2xl"></div>
            <img 
              src="/images/course/course-hero.jpg" 
              alt="AI 实战营课程"
              class="relative w-full max-w-lg aspect-[4/3] object-cover rounded-3xl shadow-2xl"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Course Modules -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Module 1 -->
        <div class="bg-gradient-to-r from-orange-50 to-white border-2 border-orange-200 rounded-2xl p-8 hover:border-orange-500 transition-colors">
          <div class="flex items-start gap-6">
            <div class="bg-orange-500 text-white w-16 h-16 rounded-xl flex items-center justify-center text-2xl font-bold flex-shrink-0">
              1
            </div>
            <div class="flex-1">
              <h2 class="text-2xl font-bold text-gray-900 mb-3">AI 获客系统</h2>
              <p class="text-gray-600 text-lg mb-4">
                从 0 到 1 搭建自动引流系统，让精准客户主动找上门
              </p>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  自动引流系统搭建
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  精准客户定位
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  流量转化漏斗设计
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Module 2 -->
        <div class="bg-gradient-to-r from-orange-50 to-white border-2 border-orange-200 rounded-2xl p-8 hover:border-orange-500 transition-colors">
          <div class="flex items-start gap-6">
            <div class="bg-orange-500 text-white w-16 h-16 rounded-xl flex items-center justify-center text-2xl font-bold flex-shrink-0">
              2
            </div>
            <div class="flex-1">
              <h2 class="text-2xl font-bold text-gray-900 mb-3">AI 内容系统</h2>
              <p class="text-gray-600 text-lg mb-4">
                一键量产，一人顶一个内容团队（文案/图片/视频）
              </p>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  AI 文案批量生成
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  AI 图片批量制作
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  AI 视频快速产出
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Module 3 -->
        <div class="bg-gradient-to-r from-orange-50 to-white border-2 border-orange-200 rounded-2xl p-8 hover:border-orange-500 transition-colors">
          <div class="flex items-start gap-6">
            <div class="bg-orange-500 text-white w-16 h-16 rounded-xl flex items-center justify-center text-2xl font-bold flex-shrink-0">
              3
            </div>
            <div class="flex-1">
              <h2 class="text-2xl font-bold text-gray-900 mb-3">AI 成交系统</h2>
              <p class="text-gray-600 text-lg mb-4">
                智能话术 + 自动化跟进，把咨询变成订单的转化闭环
              </p>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  智能话术库搭建
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  自动化跟进流程
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  转化闭环设计
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Module 4 -->
        <div class="bg-gradient-to-r from-orange-50 to-white border-2 border-orange-200 rounded-2xl p-8 hover:border-orange-500 transition-colors">
          <div class="flex items-start gap-6">
            <div class="bg-orange-500 text-white w-16 h-16 rounded-xl flex items-center justify-center text-2xl font-bold flex-shrink-0">
              4
            </div>
            <div class="flex-1">
              <h2 class="text-2xl font-bold text-gray-900 mb-3">AI 交付系统</h2>
              <p class="text-gray-600 text-lg mb-4">
                标准化 SOP+ 工具链，让服务可复制、利润可放大
              </p>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  标准化 SOP 设计
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  工具链整合
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2 font-bold">✓</span>
                  服务规模化
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section with QR Code -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-6">
      <div class="bg-white rounded-3xl shadow-xl overflow-hidden">
        <div class="grid md:grid-cols-2 gap-12 p-12">
          <!-- Left: CTA Text -->
          <div class="flex flex-col justify-center">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">立即报名</h2>
            <p class="text-gray-600 text-lg mb-6">
              添加微信，获取课程详情和优惠信息
            </p>
            <div class="space-y-3">
              <div class="flex items-center gap-3 text-gray-700">
                <span class="text-orange-500 font-bold">✓</span>
                <span>一对一咨询</span>
              </div>
              <div class="flex items-center gap-3 text-gray-700">
                <span class="text-orange-500 font-bold">✓</span>
                <span>课程大纲详解</span>
              </div>
              <div class="flex items-center gap-3 text-gray-700">
                <span class="text-orange-500 font-bold">✓</span>
                <span>限时优惠价格</span>
              </div>
            </div>
          </div>
          
          <!-- Right: QR Code -->
          <div class="flex flex-col items-center justify-center">
            <div class="bg-orange-50 p-6 rounded-2xl mb-4">
              <img 
                src="/images/qrcode/wechat.jpg" 
                alt="微信二维码" 
                class="w-56 h-56 rounded-xl shadow-md"
              />
            </div>
            <p class="text-lg font-medium text-gray-900">微信：m347820705</p>
            <p class="text-gray-500 text-sm mt-2">扫一扫上面的二维码图案，加我为朋友</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
