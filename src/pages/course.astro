---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="课程">
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-5xl font-bold text-center mb-4">AI 实战营</h1>
      <p class="text-center text-gray-500 mb-12 text-xl">我们只解决 4 个死穴</p>
      
      <!-- Course Modules -->
      <div class="space-y-8">
        <!-- Module 1 -->
        <div class="bg-gradient-to-r from-orange-50 to-white border-2 border-orange-200 rounded-2xl p-8 hover:border-orange-500 transition-colors">
          <div class="flex items-start gap-6">
            <div class="bg-orange-500 text-white w-16 h-16 rounded-xl flex items-center justify-center text-2xl font-bold flex-shrink-0">
              1
            </div>
            <div class="flex-1">
              <h2 class="text-2xl font-bold text-gray-900 mb-3">AI 获客系统</h2>
              <p class="text-gray-600 text-lg mb-4">
                从 0 到 1 搭建自动引流系统，让精准客户主动找上门
              </p>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  自动引流系统搭建
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  精准客户定位
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  流量转化漏斗设计
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Module 2 -->
        <div class="bg-gradient-to-r from-orange-50 to-white border-2 border-orange-200 rounded-2xl p-8 hover:border-orange-500 transition-colors">
          <div class="flex items-start gap-6">
            <div class="bg-orange-500 text-white w-16 h-16 rounded-xl flex items-center justify-center text-2xl font-bold flex-shrink-0">
              2
            </div>
            <div class="flex-1">
              <h2 class="text-2xl font-bold text-gray-900 mb-3">AI 内容系统</h2>
              <p class="text-gray-600 text-lg mb-4">
                一键量产，一人顶一个内容团队（文案/图片/视频）
              </p>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  AI 文案批量生成
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  AI 图片批量制作
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  AI 视频快速产出
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Module 3 -->
        <div class="bg-gradient-to-r from-orange-50 to-white border-2 border-orange-200 rounded-2xl p-8 hover:border-orange-500 transition-colors">
          <div class="flex items-start gap-6">
            <div class="bg-orange-500 text-white w-16 h-16 rounded-xl flex items-center justify-center text-2xl font-bold flex-shrink-0">
              3
            </div>
            <div class="flex-1">
              <h2 class="text-2xl font-bold text-gray-900 mb-3">AI 成交系统</h2>
              <p class="text-gray-600 text-lg mb-4">
                智能话术 + 自动化跟进，把咨询变成订单的转化闭环
              </p>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  智能话术库搭建
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  自动化跟进流程
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  转化闭环设计
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Module 4 -->
        <div class="bg-gradient-to-r from-orange-50 to-white border-2 border-orange-200 rounded-2xl p-8 hover:border-orange-500 transition-colors">
          <div class="flex items-start gap-6">
            <div class="bg-orange-500 text-white w-16 h-16 rounded-xl flex items-center justify-center text-2xl font-bold flex-shrink-0">
              4
            </div>
            <div class="flex-1">
              <h2 class="text-2xl font-bold text-gray-900 mb-3">AI 交付系统</h2>
              <p class="text-gray-600 text-lg mb-4">
                标准化 SOP+ 工具链，让服务可复制、利润可放大
              </p>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  标准化 SOP 设计
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  工具链整合
                </li>
                <li class="flex items-center">
                  <span class="text-orange-500 mr-2">✓</span>
                  服务规模化
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-16 text-center">
        <div class="bg-orange-500 text-white rounded-2xl p-8 inline-block">
          <h3 class="text-2xl font-bold mb-4">立即报名</h3>
          <p class="mb-6 opacity-90">添加微信，获取课程详情</p>
          <div class="flex flex-col items-center gap-4">
            <img src="/images/qrcode/wechat.jpg" alt="微信二维码" class="w-48 h-48 bg-white rounded-lg" />
            <p class="text-lg font-medium">微信：m347820705</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
