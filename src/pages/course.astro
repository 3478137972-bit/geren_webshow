---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="2026 暑期 AI 实战营 - 课程">
  <!-- 1. Hero 区域 -->
  <section class="py-20 bg-gradient-to-br from-orange-500 via-orange-400 to-amber-400">
    <div class="max-w-[1200px] mx-auto px-6 md:px-8 text-center">
      <!-- 主标题 -->
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 drop-shadow-lg">
        2026 暑期 AI 实战营
      </h1>
      
      <!-- 副标题 -->
      <p class="text-2xl md:text-3xl text-orange-100 mb-8">
        21 天掌握 AI 辅助开发，效率提升 10 倍
      </p>
      
      <!-- 课程特色 -->
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto mb-12">
        <div class="bg-white/20 backdrop-blur-sm rounded-2xl p-6">
          <div class="text-4xl mb-3">🎯</div>
          <h3 class="text-xl font-bold text-white mb-2">实战导向</h3>
          <p class="text-orange-100">4 个实战项目，学完即用</p>
        </div>
        <div class="bg-white/20 backdrop-blur-sm rounded-2xl p-6">
          <div class="text-4xl mb-3">👨🏫</div>
          <h3 class="text-xl font-bold text-white mb-2">名师指导</h3>
          <p class="text-orange-100">5 年 AI 实战专家亲授</p>
        </div>
        <div class="bg-white/20 backdrop-blur-sm rounded-2xl p-6">
          <div class="text-4xl mb-3">📜</div>
          <h3 class="text-xl font-bold text-white mb-2">结业证书</h3>
          <p class="text-orange-100">完成项目获得认证证书</p>
        </div>
      </div>
      
      <!-- CTA 按钮 -->
      <a href="#price" class="inline-flex items-center justify-center bg-white hover:bg-orange-50 text-orange-600 text-2xl font-bold px-16 py-6 rounded-2xl shadow-2xl hover:shadow-3xl transition-all transform hover:scale-105">
        立即报名
      </a>
      <p class="text-orange-100 mt-4 text-lg">早鸟价 ¥12,800 · 原价 ¥26,800</p>
    </div>
  </section>

  <!-- 2. 讲师介绍 -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-[1200px] mx-auto px-6 md:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">主讲导师</h2>
      </div>
      
      <div class="max-w-4xl mx-auto">
        <div class="bg-gradient-to-br from-orange-50 to-amber-50 rounded-3xl p-8 md:p-12 border-2 border-orange-200">
          <div class="flex flex-col md:flex-row items-center gap-8">
            <!-- 讲师照片 -->
            <img 
              src="/images/lele-profile.jpg" 
              alt="乐乐"
              class="w-40 h-40 rounded-2xl object-cover border-4 border-orange-300 shadow-xl"
            />
            
            <!-- 讲师信息 -->
            <div class="flex-1 text-center md:text-left">
              <h3 class="text-3xl font-bold text-gray-900 mb-2">乐乐</h3>
              <p class="text-orange-500 font-semibold text-lg mb-4">AI 训练师</p>
              
              <!-- 资历标签 -->
              <div class="flex flex-wrap justify-center md:justify-start gap-3 mb-6">
                <span class="bg-orange-100 text-orange-700 px-4 py-2 rounded-full font-medium">5 年 AI 实战经验</span>
                <span class="bg-blue-100 text-blue-700 px-4 py-2 rounded-full font-medium">10+ 品牌案例</span>
                <span class="bg-green-100 text-green-700 px-4 py-2 rounded-full font-medium">50+ 企业客户</span>
              </div>
              
              <!-- 资历详情 -->
              <div class="space-y-3 text-gray-700">
                <div class="flex items-start gap-3">
                  <span class="text-orange-500 text-xl">🏆</span>
                  <span>前大厂 AI 产品负责人，主导多个 AI 项目落地</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-orange-500 text-xl">📖</span>
                  <span>AI 破局俱乐部核心讲师，累计授课 1000+ 小时</span>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-orange-500 text-xl">💼</span>
                  <span>服务 50+ 企业客户，包括多家世界 500 强</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. 课程大纲（21 天日程） -->
  <section id="syllabus" class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-[1200px] mx-auto px-6 md:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">课程大纲</h2>
        <p class="text-xl text-gray-600">21 天系统学习，从入门到实战</p>
      </div>
      
      <div class="space-y-6">
        <!-- 第 1 阶段：AI 获客系统 -->
        <div class="bg-white rounded-2xl border-2 border-orange-200 overflow-hidden">
          <div class="bg-gradient-to-r from-orange-500 to-amber-500 px-8 py-4">
            <h3 class="text-2xl font-bold text-white">第 1 阶段：AI 获客系统（第 1-5 天）</h3>
          </div>
          <div class="p-8">
            <div class="space-y-4">
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-orange-500 font-bold">第 1 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">客户定位：找到你的高价值人群</div>
                  <div class="text-gray-600 text-sm">学习使用 AI 分析目标客户画像，确定市场定位</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-orange-500 font-bold">第 2 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">引流系统设计：让客户主动找你</div>
                  <div class="text-gray-600 text-sm">搭建自动引流漏斗，实现精准获客</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-orange-500 font-bold">第 3 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">流量转化漏斗：从访客到付费用户</div>
                  <div class="text-gray-600 text-sm">设计转化路径，提升转化率</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-orange-500 font-bold">第 4 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">实战案例：从 0 到 1000 粉丝</div>
                  <div class="text-gray-600 text-sm">真实案例拆解，学习成功经验</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-orange-500 font-bold">第 5 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">作业：设计你的获客系统</div>
                  <div class="text-gray-600 text-sm">完成个人获客系统设计方案</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- 第 2 阶段：AI 内容系统 -->
        <div class="bg-white rounded-2xl border-2 border-blue-200 overflow-hidden">
          <div class="bg-gradient-to-r from-blue-500 to-indigo-500 px-8 py-4">
            <h3 class="text-2xl font-bold text-white">第 2 阶段：AI 内容系统（第 6-11 天）</h3>
          </div>
          <div class="p-8">
            <div class="space-y-4">
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-blue-500 font-bold">第 6 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">AI 文案：批量生成高质量内容</div>
                  <div class="text-gray-600 text-sm">掌握 AI 文案工具，提升内容产出效率</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-blue-500 font-bold">第 7 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">AI 图片：快速制作视觉素材</div>
                  <div class="text-gray-600 text-sm">使用 AI 生成专业级图片</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-blue-500 font-bold">第 8 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">AI 视频：一人顶一个团队</div>
                  <div class="text-gray-600 text-sm">AI 视频生成与编辑技巧</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-blue-500 font-bold">第 9 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">内容日历：30 天内容规划</div>
                  <div class="text-gray-600 text-sm">制定系统化内容发布计划</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-blue-500 font-bold">第 10 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">多平台分发策略</div>
                  <div class="text-gray-600 text-sm">全平台内容分发与运营</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-blue-500 font-bold">第 11 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">作业：制作你的内容矩阵</div>
                  <div class="text-gray-600 text-sm">完成个人内容矩阵搭建</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- 第 3 阶段：AI 成交系统 -->
        <div class="bg-white rounded-2xl border-2 border-green-200 overflow-hidden">
          <div class="bg-gradient-to-r from-green-500 to-emerald-500 px-8 py-4">
            <h3 class="text-2xl font-bold text-white">第 3 阶段：AI 成交系统（第 12-16 天）</h3>
          </div>
          <div class="p-8">
            <div class="space-y-4">
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-green-500 font-bold">第 12 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">智能话术库：应对各种客户问题</div>
                  <div class="text-gray-600 text-sm">搭建 AI 话术库，提升响应效率</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-green-500 font-bold">第 13 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">自动化跟进：7 天转化流程</div>
                  <div class="text-gray-600 text-sm">设计自动化客户跟进系统</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-green-500 font-bold">第 14 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">价格策略：如何定价利润最大化</div>
                  <div class="text-gray-600 text-sm">学习科学定价方法</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-green-500 font-bold">第 15 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">成交案例：从咨询到订单</div>
                  <div class="text-gray-600 text-sm">真实成交案例拆解</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-green-500 font-bold">第 16 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">作业：设计你的成交流程</div>
                  <div class="text-gray-600 text-sm">完成个人成交系统设计</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- 第 4 阶段：AI 交付系统 -->
        <div class="bg-white rounded-2xl border-2 border-purple-200 overflow-hidden">
          <div class="bg-gradient-to-r from-purple-500 to-pink-500 px-8 py-4">
            <h3 class="text-2xl font-bold text-white">第 4 阶段：AI 交付系统（第 17-21 天）</h3>
          </div>
          <div class="p-8">
            <div class="space-y-4">
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-purple-500 font-bold">第 17 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">标准化 SOP：让服务可复制</div>
                  <div class="text-gray-600 text-sm">设计标准化服务流程</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-purple-500 font-bold">第 18 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">工具链整合：提升交付效率</div>
                  <div class="text-gray-600 text-sm">整合 AI 工具提升效率</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-purple-500 font-bold">第 19 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">客户管理：从单次到长期</div>
                  <div class="text-gray-600 text-sm">建立长期客户关系</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-purple-500 font-bold">第 20 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">规模化：从 1 到 100 客户</div>
                  <div class="text-gray-600 text-sm">学习规模化交付方法</div>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="w-20 flex-shrink-0 text-purple-500 font-bold">第 21 天</span>
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">毕业项目：搭建你的交付系统</div>
                  <div class="text-gray-600 text-sm">完成最终实战项目</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. 价格信息 -->
  <section id="price" class="py-16 md:py-20 bg-gradient-to-br from-orange-500 via-orange-400 to-amber-400">
    <div class="max-w-[1200px] mx-auto px-6 md:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">限时优惠</h2>
        <p class="text-xl text-orange-100">早鸟价仅剩最后名额</p>
      </div>
      
      <div class="max-w-3xl mx-auto">
        <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
          <!-- 价格阶梯 -->
          <div class="bg-gradient-to-r from-orange-500 to-amber-500 px-8 py-6 text-center">
            <div class="inline-block bg-white/20 backdrop-blur-sm text-white px-6 py-2 rounded-full text-sm font-semibold">
              🔥 早鸟优惠 · 限时抢购
            </div>
          </div>
          
          <!-- 价格展示 -->
          <div class="p-8 md:p-12">
            <!-- 价格对比 -->
            <div class="flex items-center justify-center gap-6 mb-8">
              <div class="text-center">
                <div class="text-4xl text-gray-400 line-through font-bold">¥26,800</div>
                <div class="text-gray-500 text-sm mt-1">原价</div>
              </div>
              <div class="text-3xl text-orange-500 font-bold">→</div>
              <div class="text-center">
                <div class="text-6xl text-orange-500 font-bold">¥12,800</div>
                <div class="text-orange-600 text-sm mt-1 font-semibold">早鸟价</div>
              </div>
            </div>
            
            <!-- 立省金额 -->
            <div class="bg-red-50 rounded-xl p-4 mb-8 text-center">
              <div class="text-red-600 font-bold text-lg"> 立省 ¥14,000 · 52% OFF</div>
            </div>
            
            <!-- 课程包含 -->
            <div class="space-y-4 mb-8">
              <div class="flex items-center gap-4">
                <span class="w-8 h-8 bg-green-100 text-green-600 rounded-full flex items-center justify-center font-bold">✓</span>
                <span class="text-gray-700 text-lg">21 天系统课程（100+ 课时）</span>
              </div>
              <div class="flex items-center gap-4">
                <span class="w-8 h-8 bg-green-100 text-green-600 rounded-full flex items-center justify-center font-bold">✓</span>
                <span class="text-gray-700 text-lg">4 大实战项目 + 作业批改</span>
              </div>
              <div class="flex items-center gap-4">
                <span class="w-8 h-8 bg-green-100 text-green-600 rounded-full flex items-center justify-center font-bold">✓</span>
                <span class="text-gray-700 text-lg">终身社群答疑 + 资源对接</span>
              </div>
              <div class="flex items-center gap-4">
                <span class="w-8 h-8 bg-green-100 text-green-600 rounded-full flex items-center justify-center font-bold">✓</span>
                <span class="text-gray-700 text-lg">结业证书 + 优秀学员推荐</span>
              </div>
              <div class="flex items-center gap-4">
                <span class="w-8 h-8 bg-green-100 text-green-600 rounded-full flex items-center justify-center font-bold">✓</span>
                <span class="text-gray-700 text-lg">7 天无理由退款保障</span>
              </div>
            </div>
            
            <!-- CTA 按钮 -->
            <a href="https://u.wechat.com/xxx" class="block w-full bg-gradient-to-r from-orange-500 to-amber-500 hover:from-orange-600 hover:to-amber-600 text-white text-2xl font-bold px-12 py-6 rounded-2xl shadow-lg hover:shadow-xl transition-all transform hover:scale-105 text-center">
              立即报名 · 抢占早鸟名额
            </a>
            
            <!-- 微信二维码 -->
            <div class="mt-8 pt-8 border-t-2 border-gray-100 text-center">
              <p class="text-gray-600 mb-4 font-medium">或扫码咨询课程详情</p>
              <img 
                src="/images/qrcode/wechat.jpg" 
                alt="微信二维码"
                class="w-40 h-40 mx-auto rounded-lg border-2 border-gray-200"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. 底部 CTA -->
  <section class="py-16 md:py-20 bg-gray-900">
    <div class="max-w-[1200px] mx-auto px-6 md:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">
        立即加入，开启 AI 商业之旅
      </h2>
      <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        21 天系统学习，4 大实战项目，终身社群支持
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#price" class="inline-flex items-center justify-center bg-orange-500 hover:bg-orange-600 text-white text-xl font-bold px-12 py-5 rounded-2xl shadow-lg hover:shadow-xl transition-all transform hover:scale-105">
          立即报名 ¥12,800
        </a>
        <a href="https://u.wechat.com/xxx" class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white text-lg font-semibold px-8 py-5 rounded-2xl backdrop-blur-sm transition-all">
          💬 扫码咨询
        </a>
      </div>
      <p class="text-gray-400 mt-8 text-sm">
        🔥 早鸟价仅剩最后名额 · 错过恢复原价¥26,800
      </p>
    </div>
  </section>
</BaseLayout>
