  <!-- 脚本：手风琴交互 -->
  <script>
    function toggleModule(moduleId) {
      const module = document.getElementById(moduleId);
      const icon = document.getElementById(moduleId + '-icon');
      if (module && icon) {
        const isHidden = module.classList.contains('hidden');
        // 关闭所有模块
        document.querySelectorAll('[id^="module"]').forEach(el => {
          if (el.id.endsWith('-icon')) {
            el.style.transform = 'rotate(0deg)';
          } else {
            el.classList.add('hidden');
          }
        });
        // 打开当前模块
        if (isHidden) {
          module.classList.remove('hidden');
          icon.style.transform = 'rotate(180deg)';
        }
      }
    }

    function toggleFaq(faqId) {
      const faq = document.getElementById(faqId);
      const icon = document.getElementById(faqId + '-icon');
      if (faq && icon) {
        const isHidden = faq.classList.contains('hidden');
        // 关闭所有 FAQ
        document.querySelectorAll('[id^="faq"]').forEach(el => {
          if (el.id.endsWith('-icon')) {
            el.style.transform = 'rotate(0deg)';
          } else {
            el.classList.add('hidden');
          }
        });
        // 打开当前 FAQ
        if (isHidden) {
          faq.classList.remove('hidden');
          icon.style.transform = 'rotate(180deg)';
        }
      }
    }
  </script>
